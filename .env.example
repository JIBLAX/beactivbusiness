VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# PIN gate + Supabase auto-login. Set in .env.local (gitignored).
VITE_PIN_CODE=
VITE_AUTO_EMAIL=
VITE_AUTO_PASS=

# Bootstrap-only. Leave unset (or false) in steady state. Set to "true" temporarily
# on the very first install if the auto-login user does not yet exist in Supabase
# auth — this lets PinScreen create it, then sign in. Remove afterwards so failed
# sign-ins surface as errors instead of silently creating new users.
VITE_ALLOW_AUTO_SIGNUP=
